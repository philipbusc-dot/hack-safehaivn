// SafeHAIVN — Pandemic Survival Intelligence System
// Prisma schema. Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Feature 4 — AI Survival Briefing System
model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Authentication — site accounts.
// role: "admin" (may edit Map data) | "survivor" (standard user).
// Signup only ever creates survivors; admins are seeded (see prisma/seed.ts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         String   @default("survivor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  photoUrl     String?
  lat          Float? // for nearby matching
  lng          Float?

  // Optional: a survivor isn't required to pick a country at signup.
  // Populated later by the risk/connect features.
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id])

  description String?
  stats       SurvivalStat[]
}

model SurvivalStat {
  id     String @id @default(cuid())
  name   String
  value  Float
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegionRisk {
  id      String @id @default(cuid())
  country String @unique // one profile per country
  lat     Float
  lng     Float

  // source factors (live + derived)
  infectionRate     Float
  humidity          Float
  populationDensity Float
  airportTraffic    Float
  hospitalPressure  Float

  // computed 0–100 macro score
  regionalScore Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  countries Country[]
}

model Country {
  id                String @id @default(cuid())
  name              String @unique // "Thailand"
  code              String @unique // "TH"
  lat               Float
  lng               Float
  // static seed factors (from your CSVs)
  populationDensity Float
  airportTraffic    Float

  users        User[]
  risk         RegionRisk? @relation(fields: [regionRiskId], references: [id]) // one live risk record per country
  regionRiskId String?
}

model Survivor {
  id            String   @id @default(uuid())
  name          String
  age           Int
  bio           String
  baseLocation  String
  latitude      Float
  longitude     Float
  avatarUrl     String
  isCurrentUser Boolean  @default(false)
  createdAt     DateTime @default(now())
  supplies      Supply[]
}

model Supply {
  id         String   @id @default(uuid())
  label      String
  value      Int
  unit       String
  survivorId String
  survivor   Survivor @relation(fields: [survivorId], references: [id], onDelete: Cascade)
}

model Match {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String // "like", "love", "no"
  createdAt  DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  timestamp  String // e.g. "03:14 AM"
  createdAt  DateTime @default(now())
}

model CountryReport {
  id          Int      @id @default(autoincrement())
  countryCode String
  countryName String
  severity    String   @default("Moderate")
  cases       Int      @default(0)
  note        String   @default("")
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt
}
