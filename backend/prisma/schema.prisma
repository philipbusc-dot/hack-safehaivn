// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String // store the hash, never plaintext
  name     String
  photoUrl String?
  lat      Float? // for nearby matching
  lng      Float?

  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  description String
  stats       SurvivalStat[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SurvivalStat {
  id     String @id @default(cuid())
  name   String
  value  Float
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegionRisk {
  id      String @id @default(cuid())
  country String @unique // one profile per country
  lat     Float
  lng     Float

  // source factors (live + derived)
  infectionRate     Float
  humidity          Float
  populationDensity Float
  airportTraffic    Float
  hospitalPressure  Float

  // computed 0–100 macro score
  regionalScore Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  countries Country[]
}

model Country {
  id                String @id @default(cuid())
  name              String @unique // "Thailand"
  code              String @unique // "TH"
  lat               Float
  lng               Float
  // static seed factors (from your CSVs)
  populationDensity Float
  airportTraffic    Float

  users        User[]
  risk         RegionRisk? @relation(fields: [regionRiskId], references: [id]) // one live risk record per country
  regionRiskId String?
}

model Survivor {
  id             String   @id @default(uuid())
  name           String
  age            Int
  bio            String
  baseLocation   String
  latitude       Float
  longitude      Float
  avatarUrl      String
  isCurrentUser  Boolean  @default(false)
  createdAt      DateTime @default(now())
  supplies       Supply[]
}

model Supply {
  id         String   @id @default(uuid())
  label      String
  value      Int
  unit       String
  survivorId String
  survivor   Survivor @relation(fields: [survivorId], references: [id], onDelete: Cascade)
}

model Match {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String // "like", "love", "no"
  createdAt  DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  text       String
  timestamp  String // e.g. "03:14 AM"
  createdAt  DateTime @default(now())
}
model CountryReport{
  id Int @id @default(autoincrement())
  countryCode String 
  countryName String
  severity String @default("Moderate")
  cases Int @default(0)
  note String @default("")
  createAt DateTime  @default(now())
  updateAt DateTime @updatedAt
}
